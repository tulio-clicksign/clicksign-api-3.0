      "type": "documents",
      "attributes": {
        "filename": "",
        "template": {
          "key": "",
          "data": "{}"
        },
        "metadata": ""
      }
    }
  }
}

docs {
  Adicionar um Documento ao Envelope a partir de um Modelo/Template.
