meta {
  name: Criar Documento por Duplicar
  type: http
  seq: 4
}

post {
  url: {{base_url}}/envelopes/{{envelope_id}}/documents
  body: json
  auth: inherit
}

body:json {
  {
    "data": {
      "type": "documents",
      "attributes": {
        "filename": "",
        "duplicate": {
          "key": ""
        }
      }
    }
  }
}

docs {
  Adicionar um Documento ao Envelope a partir de um documento existente.
}
